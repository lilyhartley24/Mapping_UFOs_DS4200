<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>UFO Sightings Sequence Sunburst</title>
  <script src="https://d3js.org/d3.v7.min.js"></script>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 24px;
      background: #fafafa;
      color: #222;
    }

    h1 {
      margin: 0 0 18px 0;
      font-size: 28px;
    }

    .layout {
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 24px;
      align-items: start;
    }

    .panel,
    .chart-wrap {
      background: white;
      border: 1px solid #ddd;
      border-radius: 12px;
      padding: 16px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    #chart {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 720px;
    }

    .label {
      font-weight: bold;
      margin-bottom: 6px;
      display: block;
    }

    input,
    select,
    button {
      width: 100%;
      margin-bottom: 12px;
      padding: 10px;
      border-radius: 8px;
      border: 1px solid #ccc;
      font-size: 14px;
      box-sizing: border-box;
    }

    button {
      cursor: pointer;
      background: #222;
      color: white;
      border: none;
    }

    button:hover {
      background: #444;
    }

    .instruction {
      font-size: 13px;
      color: #666;
      margin-top: -4px;
      margin-bottom: 14px;
      line-height: 1.45;
    }

    .breadcrumb {
      font-size: 14px;
      margin-bottom: 10px;
      min-height: 22px;
    }

    .summary {
      font-size: 15px;
      line-height: 1.5;
      margin-top: 8px;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
      font-size: 14px;
    }

    .swatch {
      width: 16px;
      height: 16px;
      border-radius: 3px;
      flex-shrink: 0;
    }

    .center-text {
      text-anchor: middle;
      dominant-baseline: middle;
      pointer-events: none;
    }

    .tooltip {
      position: absolute;
      pointer-events: none;
      background: rgba(34, 34, 34, 0.95);
      color: white;
      padding: 10px 12px;
      border-radius: 8px;
      font-size: 13px;
      line-height: 1.4;
      opacity: 0;
      transition: opacity 0.15s ease;
      max-width: 280px;
    }

    .arc-path {
      stroke: white;
      stroke-width: 1;
      cursor: pointer;
    }

    .fade {
      opacity: 0.2;
    }

    code {
      background: #f4f4f4;
      padding: 2px 4px;
      border-radius: 4px;
    }
  </style>
</head>
<body>
  <h1>Interactive Sequence Sunburst: UFO Sightings by Season → Month → Week</h1>

  <div class="layout">
    <div class="panel">
      <label class="label" for="csvFile">Upload CSV</label>
      <input type="file" id="csvFile" accept=".csv" />
      <div class="instruction">
        Use <code>scrubbed.csv</code> and keep the date column set to <code>datetime</code>.
        This version is built specifically for the common UFO scrubbed dataset format.
      </div>

      <label class="label" for="dateColumn">Date column name</label>
      <input type="text" id="dateColumn" value="datetime" />

      <label class="label" for="weekMode">Week grouping</label>
      <select id="weekMode">
        <option value="month">Week of month</option>
        <option value="year">Week of year</option>
      </select>

      <button id="loadSample">Load built-in sample data</button>
      <button id="resetView">Reset chart</button>

      <div class="summary" id="summaryText">
        Upload <code>scrubbed.csv</code> or load the sample data to generate the sunburst.
      </div>

      <hr />

      <div class="label">Season colors</div>
      <div id="legend"></div>
    </div>

    <div class="chart-wrap">
      <div class="breadcrumb" id="breadcrumb">Hover over a segment to see the sequence.</div>
      <div id="chart"></div>
    </div>
  </div>

  <div class="tooltip" id="tooltip"></div>

  <script>
    const width = 760;
    const radius = width / 6;
    const chartContainer = d3.select("#chart");
    const breadcrumb = d3.select("#breadcrumb");
    const summaryText = d3.select("#summaryText");
    const tooltip = d3.select("#tooltip");

    const seasonColors = {
      Winter: "#4C78A8",
      Spring: "#72B7B2",
      Summer: "#F58518",
      Fall: "#E45756"
    };

    const monthToSeason = {
      12: "Winter", 1: "Winter", 2: "Winter",
      3: "Spring", 4: "Spring", 5: "Spring",
      6: "Summer", 7: "Summer", 8: "Summer",
      9: "Fall", 10: "Fall", 11: "Fall"
    };

    const monthNames = [
      "January", "February", "March", "April", "May", "June",
      "July", "August", "September", "October", "November", "December"
    ];

    function renderLegend() {
      const legend = d3.select("#legend");
      legend.html("");

      Object.entries(seasonColors).forEach(([season, color]) => {
        const row = legend.append("div").attr("class", "legend-item");
        row.append("div").attr("class", "swatch").style("background", color);
        row.append("div").text(season);
      });
    }

    function getSeason(date) {
      return monthToSeason[date.getMonth() + 1];
    }

    function getMonthName(date) {
      return monthNames[date.getMonth()];
    }

    function getWeekOfMonth(date) {
      return "Week " + (Math.floor((date.getDate() - 1) / 7) + 1);
    }

    function getWeekOfYear(date) {
      const start = new Date(date.getFullYear(), 0, 1);
      const diff = date - start;
      const oneDay = 24 * 60 * 60 * 1000;
      return "Week " + (Math.floor(diff / oneDay / 7) + 1);
    }

    function parseScrubbedDatetime(rawDate) {
      if (!rawDate) return null;

      const cleaned = String(rawDate).trim();
      const parts = cleaned.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2,4})(?:\s+(\d{1,2}):(\d{2}))?$/);
      if (!parts) return null;

      let month = Number(parts[1]);
      let day = Number(parts[2]);
      let year = Number(parts[3]);
      let hour = Number(parts[4] || 0);
      let minute = Number(parts[5] || 0);

      if (String(parts[3]).length === 2) {
        year += 1900;
      }

      const parsed = new Date(year, month - 1, day, hour, minute);
      return Number.isNaN(parsed.getTime()) ? null : parsed;
    }

    function buildHierarchy(rows, dateColumn, weekMode) {
      const root = { name: "UFO Sightings", children: [] };
      const seasonMap = new Map();
      let validRows = 0;

      rows.forEach(row => {
        const parsed = parseScrubbedDatetime(row[dateColumn]);
        if (!parsed) return;

        validRows += 1;
        const season = getSeason(parsed);
        const month = getMonthName(parsed);
        const week = weekMode === "year" ? getWeekOfYear(parsed) : getWeekOfMonth(parsed);

        if (!seasonMap.has(season)) {
          const seasonNode = {
            name: season,
            children: [],
            color: seasonColors[season]
          };
          seasonMap.set(season, seasonNode);
          root.children.push(seasonNode);
        }

        const seasonNode = seasonMap.get(season);

        let monthNode = seasonNode.children.find(d => d.name === month);
        if (!monthNode) {
          monthNode = { name: month, children: [] };
          seasonNode.children.push(monthNode);
        }

        let weekNode = monthNode.children.find(d => d.name === week);
        if (!weekNode) {
          weekNode = { name: week, value: 0 };
          monthNode.children.push(weekNode);
        }

        weekNode.value += 1;
      });

      return { hierarchy: root, validRows };
    }

    function drawSunburst(data, totalCount) {
      chartContainer.html("");

      const svg = chartContainer
        .append("svg")
        .attr("width", width)
        .attr("height", width)
        .append("g")
        .attr("transform", `translate(${width / 2}, ${width / 2})`);

      const hierarchy = d3.hierarchy(data)
        .sum(d => d.value || 0)
        .sort((a, b) => b.value - a.value);

      d3.partition().size([2 * Math.PI, hierarchy.height + 1])(hierarchy);
      hierarchy.each(d => d.current = d);

      const arc = d3.arc()
        .startAngle(d => d.x0)
        .endAngle(d => d.x1)
        .padAngle(d => Math.min((d.x1 - d.x0) / 2, 0.01))
        .padRadius(radius * 1.5)
        .innerRadius(d => d.y0 * radius)
        .outerRadius(d => Math.max(d.y0 * radius, d.y1 * radius - 1));

      const root = hierarchy;

      const path = svg.append("g")
        .selectAll("path")
        .data(root.descendants().filter(d => d.depth))
        .join("path")
        .attr("class", "arc-path")
        .attr("fill", d => {
          if (d.depth === 1) return d.data.color || "#999";
          if (d.depth === 2) return d3.color(d.parent.data.color).brighter(0.4);
          return d3.color(d.parent.parent.data.color).brighter(0.9);
        })
        .attr("fill-opacity", d => arcVisible(d.current) ? 1 : 0)
        .attr("d", d => arc(d.current))
        .on("mouseover", function(event, d) {
          const sequence = d.ancestors().reverse().slice(1).map(node => node.data.name);
          const pct = ((100 * d.value) / totalCount).toFixed(1);

          breadcrumb.text(sequence.join(" → "));
          summaryText.html(
            `<strong>${d.data.name}</strong><br>` +
            `Sightings in this segment: ${d.value}<br>` +
            `Share of total sightings: ${pct}%`
          );

          tooltip
            .style("opacity", 1)
            .html(
              `<strong>${sequence.join(" → ")}</strong><br>` +
              `Sightings: ${d.value}<br>` +
              `Percent of total: ${pct}%`
            )
            .style("left", `${event.pageX + 14}px`)
            .style("top", `${event.pageY - 18}px`);

          const ancestors = new Set(d.ancestors());
          path.classed("fade", node => !ancestors.has(node));
        })
        .on("mousemove", function(event) {
          tooltip
            .style("left", `${event.pageX + 14}px`)
            .style("top", `${event.pageY - 18}px`);
        })
        .on("mouseout", function() {
          breadcrumb.text("Hover over a segment to see the sequence.");
          tooltip.style("opacity", 0);
          path.classed("fade", false);
        })
        .on("click", clicked);

      path.append("title")
        .text(d => `${d.ancestors().reverse().slice(1).map(node => node.data.name).join(" → ")}\n${d.value} sightings`);

      const parent = svg.append("circle")
        .datum(root)
        .attr("r", radius)
        .attr("fill", "none")
        .attr("pointer-events", "all")
        .on("click", clicked);

      svg.append("text")
        .attr("class", "center-text")
        .style("font-size", "18px")
        .style("font-weight", "bold")
        .text("UFO");

      svg.append("text")
        .attr("class", "center-text")
        .attr("dy", 22)
        .style("font-size", "13px")
        .text("Sightings");

      function clicked(event, p) {
        parent.datum(p.parent || root);

        root.each(d => d.target = {
          x0: Math.max(0, Math.min(1, (d.x0 - p.x0) / (p.x1 - p.x0))) * 2 * Math.PI,
          x1: Math.max(0, Math.min(1, (d.x1 - p.x0) / (p.x1 - p.x0))) * 2 * Math.PI,
          y0: Math.max(0, d.y0 - p.depth),
          y1: Math.max(0, d.y1 - p.depth)
        });

        const t = svg.transition().duration(750);

        path.transition(t)
          .tween("data", d => {
            const i = d3.interpolate(d.current, d.target);
            return t => d.current = i(t);
          })
          .filter(function(d) {
            return +this.getAttribute("fill-opacity") || arcVisible(d.target);
          })
          .attr("fill-opacity", d => arcVisible(d.target) ? 1 : 0)
          .attrTween("d", d => () => arc(d.current));
      }

      function arcVisible(d) {
        return d.y1 <= 4 && d.y0 >= 1 && d.x1 > d.x0;
      }
    }

    function processRows(rows) {
      const dateColumn = document.getElementById("dateColumn").value.trim();
      const weekMode = document.getElementById("weekMode").value;
      const { hierarchy, validRows } = buildHierarchy(rows, dateColumn, weekMode);

      if (!hierarchy.children.length) {
        summaryText.text("No valid rows were found. Make sure the file is scrubbed.csv and the date column is datetime.");
        chartContainer.html("");
        return;
      }

      summaryText.html(
        `<strong>${validRows}</strong> valid sightings loaded.<br>` +
        `Hierarchy: Season → Month → ${weekMode === "year" ? "Week of Year" : "Week of Month"}`
      );

      drawSunburst(hierarchy, validRows);
    }

    document.getElementById("csvFile").addEventListener("change", event => {
      const file = event.target.files[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = e => {
        const rows = d3.csvParse(e.target.result);
        processRows(rows);
      };
      reader.readAsText(file);
    });

    document.getElementById("resetView").addEventListener("click", () => {
      chartContainer.html("");
      breadcrumb.text("Hover over a segment to see the sequence.");
      summaryText.html("Upload <code>scrubbed.csv</code> or load the sample data to generate the sunburst.");
    });

    document.getElementById("loadSample").addEventListener("click", () => {
      const sampleRows = [
        { datetime: "12/5/2025 21:00" },
        { datetime: "12/18/2025 20:30" },
        { datetime: "1/11/2025 22:10" },
        { datetime: "2/3/2025 19:45" },
        { datetime: "3/9/2025 23:15" },
        { datetime: "3/15/2025 21:25" },
        { datetime: "4/21/2025 20:20" },
        { datetime: "4/25/2025 23:10" },
        { datetime: "5/30/2025 22:40" },
        { datetime: "6/2/2025 21:55" },
        { datetime: "6/18/2025 23:05" },
        { datetime: "6/25/2025 22:15" },
        { datetime: "7/4/2025 22:30" },
        { datetime: "7/7/2025 23:00" },
        { datetime: "7/13/2025 22:20" },
        { datetime: "7/15/2025 21:35" },
        { datetime: "7/20/2025 21:50" },
        { datetime: "7/29/2025 20:45" },
        { datetime: "8/1/2025 21:05" },
        { datetime: "8/14/2025 20:10" },
        { datetime: "9/2/2025 19:30" },
        { datetime: "9/17/2025 22:00" },
        { datetime: "10/10/2025 21:40" },
        { datetime: "10/28/2025 20:25" },
        { datetime: "11/12/2025 19:50" }
      ];

      document.getElementById("dateColumn").value = "datetime";
      processRows(sampleRows);
    });

    renderLegend();
  </script>
</body>
</html>
